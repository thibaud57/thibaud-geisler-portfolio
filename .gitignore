# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma (Prisma 7 génère le client dans le code source)
/src/generated/
# bundle généré au build Docker pour `prisma db seed` en prod (cf. Dockerfile stage builder)
/prisma/seed.js

# VS Code Local History extension
.history/

# Playwright MCP (screenshots, snapshots, logs de debug)
.playwright-mcp/

# Claude Code worktrees (créés dynamiquement lors des dispatches parallèles)
.claude/worktrees/

# Claude Code scheduling lock (PID + sessionId, recréé à chaque session)
.claude/scheduled_tasks.lock

# Assets locaux (servis par /api/assets en dev, volume Docker en prod)
/assets/*
!/assets/.gitkeep
