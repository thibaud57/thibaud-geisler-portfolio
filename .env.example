# === App ===
NEXT_PUBLIC_SITE_URL=        # https://thibaud-geisler.com en prod | http://localhost:3000 en dev
ASSETS_PATH=                 # dev: ./assets | prod: /app/assets

# === Database ===
# ⚠️ POSTGRES_* (credentials init Docker) doivent correspondre aux credentials de DATABASE_URL
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio
POSTGRES_DB=portfolio
DATABASE_URL=postgresql://portfolio:portfolio@postgres:5432/portfolio

# === SMTP ===
SMTP_HOST=
SMTP_PORT=                   # 587 (STARTTLS) | 465 (TLS)
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# === Calendly (Feature 1 sub 04 — page /contact) ===
# URL du widget inline pour la prise de rendez-vous sur /contact
# Format : https://calendly.com/<slug>/<event-type>
# Laisser vide pour afficher le fallback "Prise de rendez-vous bientôt disponible"
NEXT_PUBLIC_CALENDLY_URL=
