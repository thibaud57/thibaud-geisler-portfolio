# === App ===
NEXT_PUBLIC_SITE_URL=        # https://thibaud-geisler.com en prod | http://localhost:3000 en dev
ASSETS_PATH=                 # dev: ./assets | prod: /app/assets

# === Database (dev local) ===
# POSTGRES_* : credentials init du Postgres local (lus par compose.override.yaml). Si modifiés, mettre à jour DATABASE_URL en conséquence.
# En prod Dokploy : ignorés (Postgres Database Dokploy a ses propres credentials, DATABASE_URL injectée via Dokploy UI).
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio
POSTGRES_DB=portfolio
# DATABASE_URL : utilisé par Prisma en dev natif (`just dev`). Host = localhost car compose.override expose le port 5432.
# `just docker-up` (profile validation) override automatiquement vers `postgres:5432` (DNS compose interne).
DATABASE_URL=postgresql://portfolio:portfolio@localhost:5432/portfolio

# === SMTP ===
SMTP_HOST=
SMTP_PORT=                   # 587 (STARTTLS) | 465 (TLS)
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
MAIL_TO=

# === Calendly ===
# Une URL par locale (event types Calendly distincts FR/EN).
NEXT_PUBLIC_CALENDLY_URL_FR= # https://calendly.com/<slug>/<event-type-fr>
NEXT_PUBLIC_CALENDLY_URL_EN= # https://calendly.com/<slug>/<event-type-en>
